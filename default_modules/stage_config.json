{
  "schema_version": "0.1.0",
  "created": "2026-05-20",
  "description": "Stagewise evidence-availability configuration for Vestibular-BayesSeed default modules.",
  "intended_use": "Research and educational demonstration only; not a validated clinical decision-support system.",
  "stage_order": [
    "history",
    "bedside",
    "audiometry",
    "vestibular_test",
    "imaging"
  ],
  "stages": [
    {
      "id": "history",
      "order": 1,
      "display_name": "History / demographics",
      "description": "Information typically available from initial history, symptom timing/triggers, comorbidity, and demographics."
    },
    {
      "id": "bedside",
      "order": 2,
      "display_name": "Bedside examination",
      "description": "Positional testing, observed nystagmus patterns, bedside neurologic red flags, and other examination findings."
    },
    {
      "id": "audiometry",
      "order": 3,
      "display_name": "Audiometry",
      "description": "Audiometric evidence such as low-/mid-frequency sensorineural hearing loss."
    },
    {
      "id": "vestibular_test",
      "order": 4,
      "display_name": "Vestibular laboratory testing",
      "description": "vHIT, caloric, rotary-chair, VEMP, ECoG, or other vestibular laboratory evidence."
    },
    {
      "id": "imaging",
      "order": 5,
      "display_name": "Imaging / advanced evidence",
      "description": "MRI hydrops evidence, central MRI lesion evidence, and late-stage adjudication evidence."
    }
  ],
  "stage_aliases": {
    "demographics": "history",
    "history_only": "history",
    "physical_exam": "bedside",
    "positional_testing": "bedside",
    "hearing_test": "audiometry",
    "vestibular_lab": "vestibular_test",
    "mri": "imaging"
  },
  "special_composite_nodes": {
    "central_neurologic_sign_or_central_mri_lesion": {
      "primary_stage": "bedside_or_imaging",
      "components": [
        {
          "component": "central neurologic sign",
          "stage": "bedside"
        },
        {
          "component": "central MRI lesion",
          "stage": "imaging"
        }
      ],
      "handling_note": "For strict stagewise experiments, split this composite into bedside central signs and imaging central lesion nodes; for the seed modules it is kept as a single cross-cutting competing-evidence node."
    }
  },
