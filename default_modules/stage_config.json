  "derived_node_policy": {
    "calculation": "Derived nodes are calculated from available parent values using their logistic CPD intercepts and edge weights.",
    "missing_parent_policy": "Missing parents are ignored/unobserved, not set to 0 as negative evidence unless a specific negative input node is explicitly present.",
    "default_downstream_propagation": "threshold",
    "threshold": "A derived node is propagated as active when its posterior probability is >= 0.5; the engine can alternatively use soft probability propagation."
  },
  "diagnosis_node_policy": {
    "intercept_warning": "Default disease-node intercepts are illustrative placeholders, not calibrated prevalence estimates.",
    "recommended_use": "For validation studies, set intercepts by target clinical setting, referral pathway, and stage before locking the model."
  }
