{
  "schema_version": "0.1.0",
  "created": "2026-05-20",
  "intended_use": "Research and educational demonstration only; not a validated clinical decision-support system.",
  "cpd_family": "binary logistic CPD",
  "missingness_policy": "Unobserved inputs are treated as missing/unobserved, not as negative evidence unless a specific negative input node is set to 1.",
  "coefficient_policy": {
    "initialization_rule": "beta_init = clip(q * p * beta0, -2.5, +2.5)",
    "beta0_sources": [
      "ln(LR+)",
      "ln(LR-)",
      "ln(OR)",
      "capped qualitative prior"
    ],
    "clip": [
      -2.5,
      2.5
    ],
    "note": "Default coefficients are literature-informed starting values, not clinically validated calibration parameters."
  },
  "module_id": "presbyvestibulopathy_with_bvp_competitor",
  "display_name": "Presbyvestibulopathy with bilateral vestibulopathy competitor",
  "version": "0.1.1",
  "module_role": "Worked example for chronic vestibular hypofunction, PVP/BVP threshold separation, and BVP syndrome-test concordance.",
  "target_diseases": [
    {
      "id": "dx_presbyvestibulopathy",
      "display_name": "Presbyvestibulopathy",
      "intercept": -3.2,
      "intercept_policy": "Placeholder specialty-clinic prior; PVP is setting- and comorbidity-dependent."
    },
    {
      "id": "dx_bilateral_vestibulopathy",
      "display_name": "Bilateral vestibulopathy",
      "intercept": -3.5,
      "intercept_policy": "Placeholder specialty-clinic prior; adjust by referral pathway."
    }
  ],
  "threshold_notes": {
    "pvp_mild_bilateral": "vHIT gain <0.8 and >0.6 bilaterally, caloric responses <25 deg/s and >6 deg/s per ear, or rotary-chair gain >0.1 and <0.3.",
    "bvp_severe_bilateral": "vHIT gain <0.6 bilaterally, caloric sum <6 deg/s per ear, or rotary-chair gain <0.1 with phase lead >68 degrees."
  },
