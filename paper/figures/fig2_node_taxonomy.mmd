flowchart TB
    subgraph Inputs[Raw input nodes]
        I1[Symptom timing/triggers]
        I2[Positional nystagmus]
        I3[Audiometry]
        I4[Vestibular tests]
        I5[Imaging/red flags]
    end

    subgraph Derived[Derived clinical constructs]
        D1[Brief triggered positional syndrome]
        D2[Canal-specific positional pattern]
        D3[Auditory cluster]
        D4[Low-frequency cochlear pattern]
        D5[Mild/severe bilateral hypofunction]
        D6[Central or competing pattern]
    end

    subgraph Targets[Target disease nodes]
        T1[Dx.BPPV]
        T2[Dx.MD]
        T3[Dx.PVP]
        T4[Dx.BVP]
    end

    I1 --> D1
    I2 --> D2
    I3 --> D3
    I3 --> D4
    I4 --> D5
    I5 --> D6

    D1 --> T1
    D2 --> T1
    D3 --> T2
    D4 --> T2
    D5 --> T3
    D5 --> T4
    D6 -. competing edge .-> T1
    D6 -. competing edge .-> T2
    D6 -. competing edge .-> T3
